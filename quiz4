<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quiz Histoire – Mini Jeu</title>
<style>
  body {
    font-family: 'Arial', sans-serif;
    background: linear-gradient(135deg,#f0f2f5,#cfe2f3);
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    transition: background 0.5s;
  }
  #quiz-container {
    background: #fff;
    padding: 30px;
    border-radius: 20px;
    width: 600px;
    text-align: center;
    box-shadow: 0 0 30px rgba(0,0,0,0.3);
    position: relative;
    transition: transform 0.4s, box-shadow 0.3s;
  }
  #progress-bar-container {
    background: #e0e0e0;
    width: 100%;
    height: 15px;
    border-radius: 10px;
    margin-bottom: 15px;
  }
  #progress-bar {
    background: #007BFF;
    height: 100%;
    width: 0%;
    border-radius: 10px;
    transition: width 0.5s ease;
  }
  #timer {
    font-size: 18px;
    margin-bottom: 15px;
    font-weight: bold;
    color: #555;
  }
  #question {
    font-size: 24px;
    margin-bottom: 20px;
    min-height: 70px;
  }
  .option {
    background: #e4e4e4;
    padding: 15px;
    margin: 10px 0;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.3s;
    font-size: 18px;
  }
  .option:hover {
    background: #d1d1d1;
    transform: scale(1.05);
  }
  .correct {
    background-color: #28a745 !important;
    color: white;
    box-shadow: 0 0 15px #28a745;
    animation: pulse 0.4s;
  }
  .incorrect {
    background-color: #dc3545 !important;
    color: white;
    box-shadow: 0 0 15px #dc3545;
    animation: shake 0.4s;
  }
  @keyframes pulse {
    0% {transform: scale(1);}
    50% {transform: scale(1.1);}
    100% {transform: scale(1);}
  }
  @keyframes shake {
    0% {transform: translateX(0);}
    25% {transform: translateX(-5px);}
    50% {transform: translateX(5px);}
    75% {transform: translateX(-5px);}
    100% {transform: translateX(0);}
  }
  #next-btn {
    margin-top: 20px;
    padding: 15px 40px;
    border: none;
    background: #007BFF;
    color: white;
    border-radius: 10px;
    font-size: 18px;
    cursor: pointer;
    display: none;
    transition: background 0.3s;
  }
  #next-btn:hover {
    background: #0056b3;
  }
  #score-display {
    font-size: 20px;
    margin-top: 15px;
    font-weight: bold;
    color: #333;
  }
</style>
</head>
<body>

<div id="quiz-container">
  <div id="progress-bar-container">
    <div id="progress-bar"></div>
  </div>
  <div id="timer">Temps restant : 10s</div>
  <div id="question">Question ici</div>
  <div id="options"></div>
  <button id="next-btn">Suivant</button>
  <div id="score-display">Score : 0</div>
</div>

<!-- Sons -->
<audio id="correct-sound" src="https://www.soundjay.com/buttons/sounds/button-4.mp3"></audio>
<audio id="wrong-sound" src="https://www.soundjay.com/buttons/sounds/button-10.mp3"></audio>
<audio id="levelup-sound" src="https://www.soundjay.com/buttons/sounds/button-3.mp3"></audio>

<script>
const allQuestions = [
  { question: "Qui a découvert l'Amérique en 1492 ?", options: ["Christopher Columbus", "Vasco de Gama", "Marco Polo", "Amerigo Vespucci"], answer: "Christopher Columbus", difficulty:"facile" },
  { question: "Quelle année marque le début de la Révolution française ?", options: ["1789", "1776", "1804", "1799"], answer: "1789", difficulty:"facile" },
  { question: "Qui était le pharaon pendant la construction des grandes pyramides ?", options: ["Ramsès II", "Khéops", "Toutankhamon", "Akhenaton"], answer: "Khéops", difficulty:"moyen" },
  { question: "Quelle guerre a eu lieu entre 1914 et 1918 ?", options: ["La Première Guerre mondiale", "La Seconde Guerre mondiale", "La Guerre de Cent Ans", "La Guerre de Corée"], answer: "La Première Guerre mondiale", difficulty:"facile" },
  { question: "En quelle année la chute de l'Empire romain d'Occident a-t-elle eu lieu ?", options: ["476", "410", "395", "500"], answer: "476", difficulty:"moyen" },
  { question: "Qui a inventé l'imprimerie ?", options: ["Johannes Gutenberg", "Leonardo da Vinci", "Isaac Newton", "Galilée"], answer: "Johannes Gutenberg", difficulty:"moyen" },
  { question: "Quelle civilisation a construit Machu Picchu ?", options: ["Incas", "Mayas", "Aztèques", "Égyptiens"], answer: "Incas", difficulty:"difficile" },
  { question: "Quel événement marque la fin de la Seconde Guerre mondiale ?", options: ["Bombes atomiques sur le Japon", "Invasion de la Normandie", "Chute du mur de Berlin", "Révolution russe"], answer: "Bombes atomiques sur le Japon", difficulty:"moyen" },
  { question: "Qui était le leader de l'Empire mongol ?", options: ["Gengis Khan", "Tamerlan", "Kublai Khan", "Attila"], answer: "Gengis Khan", difficulty:"difficile" },
  { question: "Quand Christophe Colomb a-t-il navigué pour la première fois vers le Nouveau Monde ?", options: ["1492", "1502", "1485", "1510"], answer: "1492", difficulty:"facile" }
];

let quizQuestions = [];
let currentQuestionIndex = 0;
let score = 0;
let quizLength = 5;
let timer;
let timeLeft = 10;

const quizContainer = document.getElementById('quiz-container');
const progressBar = document.getElementById('progress-bar');
const timerEl = document.getElementById('timer');
const questionEl = document.getElementById('question');
const optionsEl = document.getElementById('options');
const nextBtn = document.getElementById('next-btn');
const scoreDisplay = document.getElementById('score-display');

const correctSound = document.getElementById('correct-sound');
const wrongSound = document.getElementById('wrong-sound');
const levelupSound = document.getElementById('levelup-sound');

function startQuiz() {
  quizQuestions = shuffleArray([...allQuestions]).slice(0, quizLength);
  currentQuestionIndex = 0;
  score = 0;
  scoreDisplay.textContent = `Score : ${score}`;
  updateProgressBar();
  loadQuestion();
}

function loadQuestion() {
  clearInterval(timer);
  timeLeft = 10;
  timerEl.textContent = `Temps restant : ${timeLeft}s`;
  timer = setInterval(updateTimer, 1000);

  const currentQuiz = quizQuestions[currentQuestionIndex];
  questionEl.textContent = currentQuiz.question;
  optionsEl.innerHTML = '';
  nextBtn.style.display = 'none';
  updateProgressBar();

  const shuffledOptions = shuffleArray([...currentQuiz.options]);
  shuffledOptions.forEach(option => {
    const button = document.createElement('div');
    button.textContent = option;
    button.classList.add('option');
    button.addEventListener('click', () => selectOption(option, button, currentQuiz.difficulty));
    optionsEl.appendChild(button);
  });
}

function selectOption(selected, button, difficulty) {
  clearInterval(timer);
  const correct = quizQuestions[currentQuestionIndex].answer;
  Array.from(optionsEl.children).forEach(btn => btn.style.pointerEvents = 'none');

  if (selected === correct) {
    button.classList.add('correct');
    score++;
    scoreDisplay.textContent = `Score : ${score}`;
    correctSound.play();
    flashBackground('green');
    if(score % 3 === 0) levelupSound.play(); // level up tous les 3 points
  } else {
    button.classList.add('incorrect');
    wrongSound.play();
    flashBackground('red');
    Array.from(optionsEl.children).forEach(btn => {
      if (btn.textContent === correct) btn.classList.add('correct');
    });
  }

  nextBtn.style.display = 'inline-block';
}

function flashBackground(color) {
  if(color==='green') document.body.style.background = '#d4edda';
  if(color==='red') document.body.style.background = '#f8d7da';
  setTimeout(()=>{ document.body.style.background = 'linear-gradient(135deg,#f0f2f5,#cfe2f3)';}, 400);
}

function updateTimer() {
  timeLeft--;
  timerEl.textContent = `Temps restant : ${timeLeft}s`;
  if (timeLeft <= 0) {
    clearInterval(timer);
    selectOption("", {classList:{add:()=>{}}});
  }
}

nextBtn.addEventListener('click', () => {
  currentQuestionIndex++;
  if (currentQuestionIndex < quizLength) {
    loadQuestion();
  } else {
    showScore();
  }
});

function updateProgressBar() {
  const percent = ((currentQuestionIndex) / quizLength) * 100;
  progressBar.style.width = percent + '%';
}

function showScore() {
  quizContainer.innerHTML = `
    <h2>Quiz terminé !</h2>
    <p>Votre score : ${score} / ${quizLength}</p>
    <p>Un nouveau quiz démarre dans 3 secondes...</p>
  `;
  setTimeout(startQuiz, 3000);
}

function shuffleArray(array) {
  for (let i = array.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [array[i], array[j]] = [array[j], array[i]];
  }
  return array;
}

startQuiz();
</script>
</body>
</html>
